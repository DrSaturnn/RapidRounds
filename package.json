{
  "name": "rapidrounds",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "test": "node --import tsx --test tests/*.test.ts",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:seed:prod": "node --import tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && node --import tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "audit:nbme-coverage": "node --import tsx scripts/audit-nbme-coverage.ts",
    "acquire:curriculum": "node --import tsx scripts/acquire-curriculum.ts",
    "import:anking": "node --import tsx scripts/import-anking.ts",
    "enrich:anking": "node --import tsx scripts/enrich-knowledge-with-anking.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.1.0",
    "openai": "^4.77.0",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  }
}
